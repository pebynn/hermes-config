{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "量化信号→写作素材",
  "description": "finance-domain 产出量化信号摘要，writer-domain 消费生成公众号内容",
  "version": "v1",
  "type": "object",
  "properties": {
    "meta": {
      "type": "object",
      "description": "元信息",
      "properties": {
        "stream": { "const": "quant-signal-to-writer" },
        "version": { "const": "v1" },
        "producer": { "const": "finance-domain" },
        "consumer": { "const": "writer" },
        "produced_at": { "type": "string", "format": "date-time", "description": "生产时间 ISO8601" },
        "signals_date": { "type": "string", "format": "date", "description": "信号日期 YYYY-MM-DD" }
      },
      "required": ["stream", "version", "producer", "consumer", "produced_at", "signals_date"]
    },
    "summary": {
      "type": "object",
      "description": "当日信号摘要",
      "properties": {
        "market_mood": { "type": "string", "enum": ["bullish", "bearish", "neutral", "mixed"], "description": "市场情绪" },
        "overall_assessment": { "type": "string", "description": "整体判断文字摘要" },
        "key_signals_count": { "type": "integer", "minimum": 0, "description": "关键信号数量" }
      },
      "required": ["market_mood", "overall_assessment", "key_signals_count"]
    },
    "signals": {
      "type": "array",
      "description": "信号列表",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "信号唯一标识" },
          "type": { "type": "string", "enum": ["technical", "fundamental", "sentiment", "macro", "policy", "sector"], "description": "信号类型" },
          "ticker": { "type": "string", "description": "相关标的代码" },
          "title": { "type": "string", "description": "信号标题" },
          "description": { "type": "string", "description": "信号详细描述" },
          "direction": { "type": "string", "enum": ["positive", "negative", "neutral"], "description": "信号方向" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "置信度 0-1" },
          "urgency": { "type": "string", "enum": ["high", "medium", "low"], "description": "紧急程度" }
        },
        "required": ["id", "type", "title", "description", "direction", "confidence"]
      }
    },
    "charts": {
      "type": "array",
      "description": "图表引用",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "description": "图表标题" },
          "type": { "type": "string", "enum": ["kline", "volume", "indicator", "heatmap", "comparison"], "description": "图表类型" },
          "description": { "type": "string", "description": "图表内容描述" },
          "file_path": { "type": "string", "description": "图表文件路径" }
        },
        "required": ["title", "type", "description"]
      }
    },
    "recommended_sections": {
      "type": "array",
      "description": "建议文章结构",
      "items": {
        "type": "object",
        "properties": {
          "section": { "type": "string", "description": "小节标题" },
          "focus": { "type": "string", "description": "写作要点" },
          "signal_ids": { "type": "array", "items": { "type": "string" }, "description": "引用的信号ID列表" }
        },
        "required": ["section", "focus"]
      }
    }
  },
  "required": ["meta", "summary", "signals", "recommended_sections"]
}
