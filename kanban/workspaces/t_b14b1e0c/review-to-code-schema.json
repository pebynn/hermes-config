{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review-to-Code Data Bus Schema",
  "description": "Schema for the data bus file passed from reviewer to code-domain during the autonomous review-fix loop. File path: ~/.hermes/bus/review-to-code/{pr_number}-{iteration}.json",
  "type": "object",
  "required": ["pr_number", "pr_url", "branch", "iteration", "findings", "summary", "approved"],
  "properties": {
    "pr_number": {
      "type": "integer",
      "description": "GitHub PR number"
    },
    "pr_url": {
      "type": "string",
      "format": "uri",
      "description": "Full URL to the GitHub PR"
    },
    "branch": {
      "type": "string",
      "description": "Head branch name of the PR"
    },
    "base_branch": {
      "type": "string",
      "description": "Base/target branch of the PR"
    },
    "iteration": {
      "type": "integer",
      "minimum": 0,
      "description": "Current iteration number (0=initial review)"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "category", "file", "title", "description", "auto_fixable", "requires_human"],
        "properties": {
          "id": {"type": "string"},
          "severity": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
          "category": {"type": "string", "enum": ["security", "performance", "style", "logic"]},
          "file": {"type": "string"},
          "line": {"type": "integer"},
          "end_line": {"type": "integer"},
          "title": {"type": "string"},
          "description": {"type": "string"},
          "suggestion": {"type": "string"},
          "code_snippet": {"type": "string"},
          "auto_fixable": {"type": "boolean"},
          "requires_human": {"type": "boolean"}
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "Human-readable summary, e.g. '3 P0, 2 P1, 5 P2 findings'"
    },
    "approved": {
      "type": "boolean",
      "description": "Whether the PR passes review"
    },
    "reviewer_task_id": {
      "type": "string",
      "description": "Kanban task ID of the review task"
    },
    "fix_task_id": {
      "type": "string",
      "description": "Kanban task ID of the fix task (if this is a re-review)"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "findings_fixed": {"type": "integer"},
        "findings_remaining": {"type": "integer"},
        "new_findings": {"type": "integer"},
        "total_iterations": {"type": "integer"}
      }
    }
  },
  "additionalProperties": false
}
